APP_ADDR=:8080
APP_DATABASE_PATH=./data/cddm.db
APP_SHUTDOWN_TIMEOUT=10s

# Read-only GitHub access. Leave empty only for public repositories with anonymous API access.
GITHUB_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com/
GITHUB_REQUEST_TIMEOUT=15s
GITHUB_SYNC_TIMEOUT=2m
GITHUB_DEFAULT_POLL_INTERVAL=5m
GITHUB_POLL_SCAN_INTERVAL=15s
GITHUB_MAX_PAGES=10
GITHUB_MAX_ITEMS=500
GITHUB_MAX_SYNC_CONCURRENCY=4

# One production planning runtime: a separately managed long-running `opencode serve` process.
OPENCODE_ENABLED=false
OPENCODE_ENDPOINT=http://host.docker.internal:4096
OPENCODE_PROVIDER=
OPENCODE_MODEL=
OPENCODE_AGENT=prompt-planner
OPENCODE_USERNAME=opencode
OPENCODE_PASSWORD=
OPENCODE_TIMEOUT=45s
OPENCODE_MAX_REQUEST_BYTES=262144
PROMPT_FALLBACK_ENABLED=true
PROMPT_EVIDENCE_LIMIT=12
PROMPT_EVIDENCE_CHARS=4000

API_PORT=8080
WEB_PORT=3000
